# sprout's environment — copy to .env (gitignored) for local prod-mode runs.
# In production these come from Fly, never from a committed file.

# Postgres connection string (required by main.ts / migrate.ts).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sprout

# Auth (plan §5.2). Two INDEPENDENT secrets for blast-radius isolation:
#  - BETTER_AUTH_SECRET signs parent (Better Auth) cookie sessions.
#  - CHILD_SESSION_SECRET signs the child-session token (HMAC-SHA256, #34).
# Generate each with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-better-auth-secret-change-me
BETTER_AUTH_URL=http://localhost:3004
CHILD_SESSION_SECRET=dev-child-session-secret-change-me

# Port the prod server listens on (default 8080).
# PORT=8080
