# sprout's environment — copy to .env (gitignored) for local prod-mode runs.
# In production these come from Fly, never from a committed file.

# Postgres connection string (required by main.ts / migrate.ts).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sprout

# Auth (plan §5.2). Two INDEPENDENT secrets for blast-radius isolation:
#  - BETTER_AUTH_SECRET signs parent (Better Auth) cookie sessions.
#  - CHILD_SESSION_SECRET signs the child-session token (HMAC-SHA256, #34).
# Generate each with: openssl rand -base64 32
BETTER_AUTH_SECRET=dev-better-auth-secret-change-me
BETTER_AUTH_URL=http://localhost:3004
CHILD_SESSION_SECRET=dev-child-session-secret-change-me

# Pipeline (plan §3 / §5.5). The web server + the retention worker call the
# headless safety service over Fly's private network. PIPELINE_API_KEY is sent
# as x-pipeline-key and must MATCH the value set on hoe-sprout-pipeline; main.ts
# refuses to boot in prod without it. PIPELINE_URL defaults to the .flycast
# address in prod; point it at the local compose pipeline service for docker-
# stack runs (the compose file wires this automatically).
PIPELINE_API_KEY=dev-pipeline-key
# PIPELINE_URL=http://hoe-sprout-pipeline.flycast:8080

# Retention/purge worker tuning (plan §9.2, all optional — sensible defaults).
# WORKER_INTERVAL_MS=3600000            # sweep cadence (default hourly)
# RETENTION_DAYS=30                     # conversation retention window
# BEHAVIOURAL_EVENT_RETENTION_DAYS=30   # behavioural_events retention window

# Port the prod server listens on (default 8080).
# PORT=8080
