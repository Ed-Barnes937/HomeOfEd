# sprout-pipeline's environment — copy to .env (gitignored) for local runs.
# In production these come from Fly secrets, never from a committed file.

# Service-to-service auth. The web app (hoe-sprout) sends this as the
# x-pipeline-key header; index.ts refuses to start in prod without it. Must
# match PIPELINE_API_KEY set on the sprout app. Generate: openssl rand -base64 32
PIPELINE_API_KEY=dev-pipeline-key

# OpenRouter API key — the LLM credential. Lives ONLY on this app (secret
# isolation, plan §10). index.ts constructs the OpenAI client at boot and
# crashes without it.
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Port the service listens on (default 8080). The dev script pins 3005.
# PORT=8080
