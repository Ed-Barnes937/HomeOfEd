# wotd's environment — copy to .env (gitignored) for local prod-mode runs.
# In production these come from Fly secrets, never from a committed file.

# Postgres connection string (validated at boot by @hoe/db/env).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wotd

# Anthropic API key for the word generator (AnthropicWordGenerator in main.ts).
# ANTHROPIC_API_KEY=sk-ant-...

# Port the prod server listens on (default 8080).
# PORT=8080
